// Prisma 7 schema — Barnacle FEMA submission API
// Documentation: https://pris.ly/d/prisma-schema
// Connection URLs are configured in prisma.config.ts

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // Emit CJS so `node dist/server.js` loads without an ESM/CJS interop
  // shim — the rest of the project transpiles to CJS via tsconfig's
  // NodeNext+no-"type":"module" combo, and Prisma 7's default "esm"
  // output uses import.meta.url which Node refuses to load in CJS.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// Record of a FEMA disaster assistance application submission attempt.
/// Written by the submission service on both success and failure so ops
/// can audit outcomes and replay failed sessions.
model FemaSubmission {
  id                 String   @id @default(cuid())
  disasterNumber     String   @map("disaster_number")
  applicantEmail     String   @map("applicant_email")
  /// "submitted" | "error"
  status             String
  confirmationNumber String?  @map("confirmation_number")
  /// Full input payload + scraper result snapshot for auditability.
  payload            Json
  capturedAt         DateTime @default(now()) @map("captured_at")

  @@index([applicantEmail], map: "fema_submission_email_idx")
  @@index([capturedAt], map: "fema_submission_captured_at_idx")
  @@map("fema_submissions")
}
