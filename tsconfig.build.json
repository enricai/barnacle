{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "include": ["src/**/*.ts", "src/**/*.mts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
