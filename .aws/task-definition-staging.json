{
  "family": "vivian-barnacle-staging-app",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::042502209102:role/BarnacleEcsExecutionRole-staging",
  "taskRoleArn": "arn:aws:iam::042502209102:role/BarnacleEcsTaskRole-staging",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "barnacle",
      "image": "IMAGE_PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "TRUST_PROXY", "value": "true" },
        { "name": "SESSION_POOL_SIZE", "value": "3" },
        { "name": "PORT", "value": "3000" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "SCRAPER_PROVIDER", "value": "browserbase" },
        { "name": "TELEMETRY_S3_BUCKET", "value": "vivian-barnacle-telemetry-staging-042502209102-us-east-1-an" }
      ],
      "secrets": [
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:042502209102:secret:/staging/barnacle/anthropic-api-key-KXMQyX" },
        { "name": "BROWSERBASE_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:042502209102:secret:/staging/barnacle/browserbase-api-key-roLo8a" },
        { "name": "BROWSERBASE_PROJECT_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:042502209102:secret:/staging/barnacle/browserbase-project-id-AClqTi" },
        { "name": "STEEL_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:042502209102:secret:/staging/barnacle/steel-api-key-bif875" },
        { "name": "API_KEYS_HASHED", "valueFrom": "arn:aws:secretsmanager:us-east-1:042502209102:secret:/staging/barnacle/api-keys-hashed-zXQCZW" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/staging/vivian-barnacle",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "app"
        }
      },
      "stopTimeout": 120
    }
  ]
}
