{
  "name": "barnacle",
  "version": "0.1.0",
  "private": true,
  "description": "Headless Node.js API mirroring the Royal Caribbean VPS (Vendor Pricing Services) surface, powered by a Stagehand + Steel browser-automation scraper.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf node_modules dist",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "biome check src",
    "lint:fix": "biome check src --fix",
    "format": "biome format src --write",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "script": "tsx",
    "smoke": "tsx src/scripts/smoke-test.ts",
    "openapi:generate": "tsx src/scripts/generate-openapi.ts",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:local:reset": "rm -f prisma/dev.db && prisma db push",
    "db:local:setup": "prisma db push && pnpm db:seed"
  },
  "husky": {
    "hooks": {
      "pre-push": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --fix"
    ]
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^2.3.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "bottleneck": "^2.19.5",
    "croner": "^9.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "lodash": "^4.17.21",
    "lru-cache": "^11.0.2",
    "nanoid": "^5.1.11",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "steel-sdk": "^0.2.0",
    "typescript": "^6.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.3",
    "husky": "^9.1.6",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "vitest": "^3.2.3"
  }
}
