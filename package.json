{
  "name": "app-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "NODE_ENV=production next build",
    "clean": "rm -rf node_modules dist .next",
    "dev": "NODE_ENV=development next dev --turbopack",
    "start": "NODE_ENV=production next start",
    "lint": "biome check src",
    "lint:fix": "biome check src --fix",
    "format": "biome format src --write",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "script": "ts-node -r tsconfig-paths/register",
    "translations:check": "ts-node -r tsconfig-paths/register src/scripts/check-translations.ts",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:local:reset": "rm -f prisma/dev.db && prisma db push",
    "db:local:setup": "prisma db push && pnpm db:seed"
  },
  "husky": {
    "hooks": {
      "pre-push": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --fix"
    ]
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "lodash": "^4.18.1",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-intl": "^4.11.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.3",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "vitest": "^3.2.3"
  }
}
