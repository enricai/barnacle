  },
  "homepage": "https://github.com/enricai/barnacle#readme",
  "keywords": [
    "browser-automation",
    "stagehand",
    "steel",
    "scraping",
    "fastify"
  ],
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "!dist/recon/fixtures",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
