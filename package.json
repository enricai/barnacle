{
  "name": "barnacle",
  "version": "0.1.0",
  "private": true,
  "description": "Site-agnostic browser automation engine. POST a structured payload to a typed endpoint; Barnacle drives a Steel + Stagehand session through the target site and returns a structured result.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && (test -d src/sites && cp -r src/sites dist/sites || true)",
    "clean": "rm -rf node_modules dist",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node dist/server.js",
    "lint": "biome check src",
    "lint:fix": "biome check src --fix",
    "format": "biome format src --write",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "smoke": "tsx --env-file=.env src/scripts/smoke-test.ts",
    "recon:browser": "tsx --env-file=.env src/scripts/recon-browser.ts",
    "recon:generate": "tsx src/scripts/recon-generate.ts",
    "recon:http": "tsx src/scripts/recon-http.ts",
    "recon:summarize": "tsx src/scripts/recon-summarize.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.99",
    "@anthropic-ai/sdk": "^0.97.1",
    "@browserbasehq/stagehand": "^3.4.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bottleneck": "^2.19.5",
    "date-fns": "^4.2.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^5.0.2",
    "http-status-codes": "^2.3.0",
    "lru-cache": "^11.5.0",
    "nanoid": "^5.1.11",
    "p-queue": "^8.0.1",
    "p-retry": "^8.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "steel-sdk": "^0.18.0",
    "typescript": "^6.0.3",
    "undici": "8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.3",
    "husky": "^9.1.6",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "vitest": "^3.2.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "patchedDependencies": {
      "@browserbasehq/stagehand": "patches/@browserbasehq__stagehand.patch"
    }
  }
}
