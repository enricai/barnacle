    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "bottleneck": "^2.19.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^5.0.2",
    "http-status-codes": "^2.3.0",
    "lru-cache": "^11.5.2",
    "nanoid": "^6.0.0",
    "normalize-url": "^9.0.1",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "steel-sdk": "^0.18.0",
    "typescript": "^7.0.2",
    "undici": "8",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "dd-trace": "^6",
    "hot-shots": "^17",
    "vitest": "^4.1.10"
  },
  "peerDependenciesMeta": {
    "dd-trace": {
      "optional": true
    },
    "hot-shots": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dd-trace": "^6",
    "hot-shots": "^17",
    "husky": "^9.1.6",
    "pino-pretty": "^13.0.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
