# --- Application ---
APP_NAME="barnacle"
NODE_ENV="development"
PORT="3000"
HOST="0.0.0.0"
LOG_LEVEL="info"

# --- Database (Prisma + pg) ---
DATABASE_URL="postgresql://user:password@localhost:5432/barnacle_dev"
DIRECT_URL="postgresql://user:password@localhost:5432/barnacle_dev"

# --- API keys & auth ---
# Comma-separated list of bcrypt-hashed API keys. Clients pass the plaintext
# value as `Authorization: Bearer <key>`; the server verifies by comparing
# against every hash in this list. For local dev you can also populate the
# `ApiKey` table in Postgres and leave this empty.
API_KEYS_HASHED=""
# Optional bypass for local dev only — NEVER set in prod.
DEV_BYPASS_AUTH="false"

# --- Scraper (Stagehand + Steel) ---
STEEL_API_KEY=""
ANTHROPIC_API_KEY=""
STAGEHAND_MODEL="claude-sonnet-4-6"
SCRAPER_PROXY_TYPE="residential"
SESSION_POOL_SIZE="3"
# Min delay (ms) between scraper actions on a single session. Jitter is
# applied on top by bottleneck.
SCRAPER_MIN_ACTION_DELAY_MS="500"
SCRAPER_MAX_ACTION_DELAY_MS="1500"

# --- Response cache ---
# TTL for response-level memoization keyed by (endpoint, normalized body).
CACHE_TTL_MS="900000"
CACHE_MAX_ENTRIES="1000"

# --- Rate limits (Fastify) ---
# Per API-key defaults; overridden per tier at plugin-config time.
RATE_LIMIT_MAX="120"
RATE_LIMIT_WINDOW_MS="60000"

# --- Background workers ---
# Daily full refresh of sailing + pricing snapshots.
REFRESH_CRON="0 3 * * *"
# Hourly trickle change detection.
CHANGES_CRON="0 * * * *"
ENABLE_WORKERS="false"

# --- Docs / OpenAPI ---
ENABLE_DOCS="false"
