# --- Application ---
APP_NAME="barnacle"
NODE_ENV="development"
PORT="3000"
HOST="0.0.0.0"
LOG_LEVEL="info"

# --- API keys & auth ---
# Comma-separated list of bcrypt-hashed API keys. Clients pass the plaintext
# value as `Authorization: Bearer <key>`; the server verifies by comparing
# against every hash in this list.
API_KEYS_HASHED=""
# Optional bypass for local dev only — NEVER set in prod.
DEV_BYPASS_AUTH="false"

# --- Browser automation (Steel + Stagehand) ---
# Required for all browser automation submissions. Steel provides managed browser
# sessions with residential proxies; Stagehand drives the browser via LLM.
STEEL_API_KEY=""
ANTHROPIC_API_KEY=""
# Provider-prefixed form. Stagehand's modelToProviderMap is stale
# (knows only up to claude-3-7-sonnet); `anthropic/<id>` routes through
# AI-SDK's fallback and forwards the name verbatim to the Anthropic SDK.
STAGEHAND_MODEL="anthropic/claude-sonnet-4-6"
# "residential" for paid Steel tiers; "none" for free tier (Steel rejects
# useProxy=true on the hobby plan).
SCRAPER_PROXY_TYPE="residential"
# Steel's built-in CAPTCHA solver. Also requires a paid Steel plan; set
# false on the free tier.
SCRAPER_SOLVE_CAPTCHA="true"
# Anthropic SDK connect/request timeout (ms). Raise on slow network paths to api.anthropic.com.
STAGEHAND_API_TIMEOUT_MS="120000"
# TCP connect timeout for all outbound fetch calls (ms). Raised from the undici
# default of 10 s to match STAGEHAND_API_TIMEOUT_MS on slow network paths.
STAGEHAND_CONNECT_TIMEOUT_MS="120000"
SESSION_POOL_SIZE="3"
# Min/max delay (ms) between scraper actions on a single session. Jitter
# is applied on top by bottleneck.
SCRAPER_MIN_ACTION_DELAY_MS="500"
SCRAPER_MAX_ACTION_DELAY_MS="1500"
# Steel session wall-clock timeout (ms). Default is 1 hour; lower this on
# plans that enforce shorter maximum session durations.
STEEL_SESSION_TIMEOUT_MS="3600000"

# --- AWS Bedrock (optional LLM provider) ---
# Set USE_BEDROCK=true to route Stagehand's LLM calls through AWS Bedrock
# instead of the Anthropic direct API. When enabled, ANTHROPIC_API_KEY is
# not required. AWS credentials are resolved in standard SDK order: explicit
# vars below → ECS task role → EC2 instance profile → ~/.aws/credentials.
USE_BEDROCK="false"
AWS_REGION="us-east-1"
# Leave blank to use ambient IAM credentials (recommended for EC2/ECS).
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Required only for temporary credentials (STS AssumeRole).
AWS_SESSION_TOKEN=""
# Bedrock cross-region inference profile ID (us. prefix = automatic cross-region routing).
# Cross-region inference profiles use bracket notation: us.anthropic.<model>[1m]
#   us.anthropic.claude-sonnet-4-6[1m]   (default)
#   us.anthropic.claude-opus-4-7[1m]
# Standard on-demand model ARNs use colon notation: us.anthropic.<model>-v1:0
#   us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL="us.anthropic.claude-sonnet-4-6[1m]"

# --- Response cache ---
# TTL for response-level memoization keyed by (endpoint, normalized body).
CACHE_TTL_MS="900000"
CACHE_MAX_ENTRIES="1000"

# --- Rate limits (Fastify) ---
# Per API-key defaults; overridden per tier at plugin-config time.
RATE_LIMIT_MAX="120"
RATE_LIMIT_WINDOW_MS="60000"
# Trust X-Forwarded-For when behind a reverse proxy (ALB, nginx,
# Cloudflare). Set to "false" for bare-metal deploys — otherwise
# anyone can spoof X-Forwarded-For to bypass IP-based rate limiting
# on unauthenticated traffic.
TRUST_PROXY="true"

# --- Readiness ---
# /readyz returns 503 (degraded) when the scraper queue depth exceeds
# this threshold, so orchestrators shed load instead of piling requests
# onto a saturated pool. Sized against SESSION_POOL_SIZE.
READINESS_QUEUE_THRESHOLD="20"

# --- Docs / OpenAPI ---
ENABLE_DOCS="false"

# --- Per-site base URL overrides ---
# For each registered plugin, set BARNACLE_SITE_<UPPERCASE_SITE_ID>_BASE_URL
# to override its defaultBaseUrl without a source change. Underscores in the
# env key map to hyphens in the siteId (e.g. MY_SHOP → my-shop).
# Example:
# BARNACLE_SITE_MY_SHOP_BASE_URL="https://staging.my-shop.com"

# --- Telemetry & LLM judging / self-healing ---
# Master switch — set to false to disable all NDJSON telemetry writes. Useful
# when the disk path is unavailable or I/O is cost-sensitive; the capture
# sink checks this before every append.
TELEMETRY_ENABLED="true"
# Directory that holds per-run NDJSON event stream files. The event-writer
# creates <eventsDir>/<runId>.ndjson at session start.
TELEMETRY_EVENTS_DIR=".barnacle/events"
# Append-only NDJSON file that records one line per LLM/Stagehand call. Feed
# this to the judge and self-heal skills to score and repair prompts.
CALLS_NDJSON_PATH=".barnacle/calls.ndjson"
# Append-only NDJSON file that records one line per dispatch outcome —
# siteId, requestId, inbound payload, status, audit payload, duration.
# Durable source-of-truth for "what did we submit for jobId X and did it succeed."
SUBMISSIONS_NDJSON_PATH=".barnacle/submissions.ndjson"
# Rotate / drop the calls NDJSON once it exceeds this byte count. Guards
# against unbounded disk growth on long-running deployments (default: 100 MB).
TELEMETRY_MAX_FILE_SIZE_BYTES="104857600"
# Drop event-stream files older than this many milliseconds. Default is 30 days
# — long enough for a monthly judge/heal cadence (30 * 24 * 60 * 60 * 1000).
TELEMETRY_MAX_RETENTION_MS="2592000000"

# Anthropic model used by the judge script to score captured call samples.
# Defaults to the Bedrock cross-region inference profile so it reuses the
# scraper's AWS credentials without a separate billing account.
JUDGE_MODEL="us.anthropic.claude-sonnet-4-6[1m]"
# Sampling temperature for judge LLM calls. Lower values (≤ 0.3) produce more
# deterministic verdicts; raise only for exploratory runs.
JUDGE_TEMPERATURE="0.2"
# Number of call samples sent to the judge in one LLM request. Larger batches
# reduce round-trips but increase per-call token cost.
JUDGE_BATCH_SIZE="10"
# Anthropic SDK request timeout for judge calls (ms). Judge batches are larger
# than scraper calls so a longer timeout is warranted.
JUDGE_TIMEOUT_MS="120000"

# Maximum patch→replay→score iterations before giving up with BUDGET_EXHAUSTED.
SELFHEAL_MAX_ITERATIONS="5"
# Number of replay runs per iteration arm. More replays give a more stable
# pass-rate estimate; replays are cheap (no browser).
SELFHEAL_N_REPLAYS="5"
# Minimum pass rate (0..1) required to declare SUCCESS and stop iterating.
SELFHEAL_SUCCESS_THRESHOLD="0.9"
# Consecutive iterations whose pass-rate improvement is below SELFHEAL_PLATEAU_DELTA
# that triggers a PLATEAUED verdict.
SELFHEAL_PLATEAU_WINDOW="3"
# Minimum absolute improvement in pass rate between iterations to be considered
# meaningful progress; below this the run plateaus.
SELFHEAL_PLATEAU_DELTA="0.03"
# Per-replay LLM request timeout (ms). Patch replay calls are small single-turn
# requests so a tighter timeout keeps the self-heal loop fast.
SELFHEAL_TIMEOUT_MS="60000"

# testmail.app — fresh inboxes for recon runs + integration tests. The
# `--allocate-email` flag on recon-browser uses these to create unique
# {namespace}.{tag}@inbox.testmail.app addresses on demand; integration
# tests poll the inbox for receipt-confirmation emails after a submission.
# Get both values from https://testmail.app/console
TESTMAIL_API_KEY=""
TESTMAIL_NAMESPACE=""
